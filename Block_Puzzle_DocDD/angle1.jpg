"""Renderer based on DOC-DSN-035 and DOC-SPC-021."""
from __future__ import annotations

from pathlib import Path
import pygame
from typing import Optional

from .constants import SCREEN_WIDTH, SCREEN_HEIGHT
from .pieces import occupied_cells, spawn_piece
from .models import GameState


# 640x576のGB風アートワークに合わせた描画基準座標。
# TITLE/SETUP_Aは背景画像を主役にし、PLAYでは盤面とサイドバーを固定配置する。
BOARD_ORIGIN_X = 96
BOARD_ORIGIN_Y = 72
CELL_SIZE = 24
BOARD_COLS = 10
BOARD_ROWS = 18
SIDEWALL_WIDTH = 32

SIDEBAR_X = 392
SIDEBAR_Y = 84
SIDEBAR_W = 170
# sidebar.png は 252x648。幅を基準に同一比率で縮小し、縦横比を崩さない。
SIDEBAR_H = 437

PLAY_LABEL_X = SIDEBAR_X + 18
SCORE_VALUE_X = SIDEBAR_X + 76
SCORE_VALUE_Y = SIDEBAR_Y + 76
LEVEL_VALUE_X = SIDEBAR_X + 132
LEVEL_VALUE_Y = SIDEBAR_Y + 108
LINES_VALUE_X = SIDEBAR_X + 132
LINES_VALUE_Y = SIDEBAR_Y + 196
NEXT_BOX_X = SIDEBAR_X + 31
NEXT_BOX_Y = SIDEBAR_Y + 300
NEXT_BOX_W = 109
NEXT_BOX_H = 129
NEXT_LABEL_X = SIDEBAR_X + 62
NEXT_LABEL_Y = SIDEBAR_Y + 324
NEXT_PIECE_CENTER_X = SIDEBAR_X + 85
NEXT_PIECE_CENTER_Y = SIDEBAR_Y + 382
NEXT_CELL_SIZE = 16
TSPIN_LABEL_X = SIDEBAR_X + 8
TSPIN_LABEL_Y = BOARD_ORIGIN_Y - 42

SETUP_LEVEL_Y = 494
SETUP_HELP_Y = 528
SETUP_BACK_Y = 552
GAME_BG_COLOR = (0x8C, 0xA5, 0x4A)
PLAYFIELD_BG_COLOR = (0x9B, 0xBC, 0x0F)


class BitmapFont:
    """fontset の文字PNGを使う簡易ビットマップフォント。"""

    def __init__(self, font_dir: Path):
        self.glyphs: dict[str, pygame.Surface] = {}
        self.errors: list[str] = []
        name_map = {"space": " ", "hyphen": "-", "ex": "!", "qs": "?"}

        if not font_dir.exists():
            self.errors.append(f"FONT_DIR_MISSING:{font_dir}")
            return

        for p in font_dir.glob("*.png"):
            key = p.stem
            ch = name_map.get(key, key)
            if len(ch) != 1:
                continue
            try:
                self.glyphs[ch.upper()] = pygame.image.load(str(p)).convert_alpha()
            except FileNotFoundError:
                self.errors.append(f"FONT_FILE_NOT_FOUND:{p}")
            except pygame.error as exc:
                self.errors.append(f"FONT_DECODE_ERROR:{p}:{exc}")

    def render(self, text: str, scale: int = 2) -> Optional[pygame.Surface]:
        cells: list[pygame.Surface] = []
        width = 0
        height = 0
        for c in text.upper():
            g = self.glyphs.get(c) or self.glyphs.get("?")
            if g is None:
                return None
            g2 = pygame.transform.scale(g, (g.get_width() * scale, g.get_height() * scale))
            cells.append(g2)
            width += g2.get_width()
            height = max(height, g2.get_height())
        canvas = pygame.Surface((max(width, 1), max(height, 1)), pygame.SRCALPHA)
        x = 0
        for g in cells:
            canvas.blit(g, (x, 0))
            x += g.get_width()
        return canvas


class Renderer:
    def __init__(self):
        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
        self.font = pygame.font.SysFont(None, 28)
        self.big_font = pygame.font.SysFont(None, 40)
        self.asset_errors: list[str] = []
        self.assets = self._load_assets()
        self.scaled_assets: dict[tuple[str, int, int], pygame.Surface] = {}

        font_root = Path(__file__).resolve().parents[3] / "art" / "fontset"
        self.bitmap_font = BitmapFont(font_root)
        self.asset_errors.extend(self.bitmap_font.errors)

    def _load_assets(self) -> dict[str, pygame.Surface]:
        """art 配下の画像を優先利用し、異常時は理由を記録したうえでフォールバックする。"""
        art_root = Path(__file__).resolve().parents[3] / "art" / "artwork"
        mapping = {
            "bg": art_root / "puzzle.png",
            "title_bg": art_root / "puzzle-menu.png",
            "sidebar": art_root / "sidebar.png",
            "wall": art_root / "wall.png",
            "sidewall": art_root / "sidewall.png",
            "block": art_root / "brick3.png",
            "active": art_root / "brick6.png",
            "next": art_root / "brick2.png",
            "brick1": art_root / "brick1.png",
            "brick2": art_root / "brick2.png",
            "brick3": art_root / "brick3.png",
            "brick4": art_root / "brick4.png",
            "brick5center": art_root / "brick5center.png",
            "brick5end": art_root / "brick5end.png",
            "brick6": art_root / "brick6.png",
        }
        loaded: dict[str, pygame.Surface] = {}
        for key, path in mapping.items():
            try:
                loaded[key] = pygame.image.load(str(path)).convert_alpha()
            except FileNotFoundError:
                # ファイル欠落: 非致命として記録し、矩形描画へフォールバック。
                self.asset_errors.append(f"ASSET_NOT_FOUND:{key}:{path}")
            except pygame.error as exc:
                # 破損・非対応形式: 原因を記録してフォールバック。
                self.asset_errors.append(f"ASSET_DECODE_ERROR:{key}:{path}:{exc}")
        return loaded

    def _scaled_asset(self, key: str, size: tuple[int, int]) -> Optional[pygame.Surface]:
        """同一サイズの変換結果を再利用し、毎フレームの画像変換を避ける。"""
        source = self.assets.get(key)
        if source is None:
            return None
        cache_key = (key, size[0], size[1])
        if cache_key not in self.scaled_assets:
            # ピクセルアートは補間でぼかさず、輪郭を維持する。
            self.scaled_assets[cache_key] = pygame.transform.scale(source, size)
        return self.scaled_assets[cache_key]

    def draw(self, s):
        self._draw_background_for_state(s.state)

        if s.state == GameState.TITLE:
            if "title_bg" not in self.assets:
                self._center_txt("BLOCK PUZZLE", 240, scale=3)
                self._center_txt("PRESS ENTER", 300, scale=2)
                if self.asset_errors:
                    self._txt("ASSET FALLBACK ACTIVE", 10, 10)
        elif s.state == GameState.SETUP_A:
            self._center_txt(f"A-TYPE LEVEL {s.start_level}", SETUP_LEVEL_Y, scale=2)
            self._center_txt("LEFT RIGHT LEVEL ENTER START", SETUP_HELP_Y, scale=1)
            self._center_txt("ESC OR Z BACK", SETUP_BACK_Y, scale=1)
        else:
            self._draw_play(s)

        pygame.display.flip()

    def _draw_background_for_state(self, state: GameState) -> None:
        if state == GameState.SETUP_A:
            if "bg" in self.assets:
                self.screen.blit(
                    self._scaled_asset("bg", (SCREEN_WIDTH, SCREEN_HEIGHT)),
                    (0, 0),
                )
            else:
                self.screen.fill(GAME_BG_COLOR)
        elif state == GameState.TITLE:
            if "title_bg" in self.assets:
                self.screen.blit(
                    self._scaled_asset("title_bg", (SCREEN_WIDTH, SCREEN_HEIGHT)),
                    (0, 0),
                )
            else:
                self.screen.fill(GAME_BG_COLOR)
        else:
            self.screen.fill(GAME_BG_COLOR)

    def _draw_play(self, s):
        self.screen.fill(GAME_BG_COLOR)
        ox, oy, c = BOARD_ORIGIN_X, BOARD_ORIGIN_Y, CELL_SIZE
        if "sidewall" in self.assets:
            # sidewall.png は 32x24。セル高24pxを維持し、横幅だけは素材の実寸を使う。
            sidewall = self._scaled_asset("sidewall", (SIDEWALL_WIDTH, c))
            for y in range(BOARD_ROWS):
                self.screen.blit(sidewall, (ox - sidewall.get_width(), oy + y * c))
                self.screen.blit(sidewall, (ox + BOARD_COLS * c, oy + y * c))
        elif "wall" in self.assets:
            wall = self._scaled_asset("wall", (c, c))
            for y in range(BOARD_ROWS):
                self.screen.blit(wall, (ox - c, oy + y * c))
                self.screen.blit(wall, (ox + BOARD_COLS * c, oy + y * c))

        for y, row in enumerate(s.board):
            for x, v in enumerate(row):
                if y in s.line_clear_rows and s.line_clear_timer > 0 and (s.line_clear_timer // 3) % 2 == 0:
                    self._draw_cell(ox + x * c, oy + y * c, c, None)
                    continue
                self._draw_cell(ox + x * c, oy + y * c, c, self._board_cell_asset_key(v))

        if s.current:
            current_cells = occupied_cells(s.current)
            for x, y in current_cells:
                self._draw_cell(
                    ox + x * c,
                    oy + y * c,
                    c,
                    self._active_cell_asset_key(s.current.kind, s.current.rotation, x, y, current_cells),
                )

        if "sidebar" in self.assets:
            side = self._scaled_asset("sidebar", (SIDEBAR_W, SIDEBAR_H))
            self.screen.blit(side, (SIDEBAR_X, SIDEBAR_Y))

        self._right_txt(str(s.score), SCORE_VALUE_X, SCORE_VALUE_Y)
        self._hud_value(str(s.level), LEVEL_VALUE_X, LEVEL_VALUE_Y)
        self._hud_value(str(s.lines), LINES_VALUE_X, LINES_VALUE_Y)

        if s.next_visible:
            self._txt("NEXT", NEXT_LABEL_X, NEXT_LABEL_Y)
            self._draw_next_piece(s.next_kind)
        else:
            self._txt("OFF", NEXT_LABEL_X, NEXT_LABEL_Y)

        if s.state == GameState.PAUSE:
            self._center_txt("PAUSE", 8, scale=2)
        if s.state == GameState.GAMEOVER:
            self._center_txt("GAME OVER", 6, scale=2)
            self._center_txt("ENTER RETRY ESC Z TITLE", 42, scale=1)
        if s.tspin_flash > 0:
            self._txt("T-SPIN!", TSPIN_LABEL_X, TSPIN_LABEL_Y)

    def _draw_next_piece(self, kind: str) -> None:
        piece = spawn_piece(kind)
        cells = occupied_cells(piece)
        min_x = min(x for x, _ in cells)
        max_x = max(x for x, _ in cells)
        min_y = min(y for _, y in cells)
        max_y = max(y for _, y in cells)

        piece_w = (max_x - min_x + 1) * NEXT_CELL_SIZE
        piece_h = (max_y - min_y + 1) * NEXT_CELL_SIZE
        origin_x = NEXT_PIECE_CENTER_X - (piece_w // 2)
        origin_y = NEXT_PIECE_CENTER_Y - (piece_h // 2)

        for x, y in cells:
            self._draw_cell(
                origin_x + (x - min_x) * NEXT_CELL_SIZE,
                origin_y + (y - min_y) * NEXT_CELL_SIZE,
                NEXT_CELL_SIZE,
                self._active_cell_asset_key(kind, 0, x, y, cells),
            )


    def _board_cell_asset_key(self, value: int) -> Optional[str]:
        if not value:
            return None
        kind_to_asset = {"T": "brick1", "J": "brick2", "L": "brick3", "O": "brick3", "S": "brick4", "Z": "brick6"}
        if value == 5:
            return "brick5center"
        if value == 6:
            return "brick5end"
        return kind_to_asset.get(chr(value), "block")

    def _active_cell_asset_key(
        self,
        kind: str,
        rotation: int,
        x: int,
        y: int,
        cells: list[tuple[int, int]],
    ) -> str:
        kind_to_asset = {"T": "brick1", "J": "brick2", "L": "brick3", "O": "brick3", "S": "brick4", "Z": "brick6"}
        if kind != "I":
            return kind_to_asset.get(kind, "active")
        if rotation % 2 == 0:
            xs = [cell_x for cell_x, _ in cells]
            return "brick5end" if x in (min(xs), max(xs)) else "brick5center"
        ys = [cell_y for _, cell_y in cells]
        return "brick5end" if y in (min(ys), max(ys)) else "brick5center"

    def _draw_cell(self, x: int, y: int, size: int, key: Optional[str]):
        rect = pygame.Rect(x, y, size - 1, size - 1)
        if key and key in self.assets:
            cell = self._scaled_asset(key, (size - 1, size - 1))
            self.screen.blit(cell, rect.topleft)
        else:
            color = (80, 80, 80) if key == "block" else (120, 200, 120) if key else PLAYFIELD_BG_COLOR
            pygame.draw.rect(self.screen, color, rect)

    def _txt(self, t, x, y):
        bmp = self.bitmap_font.render(t, scale=1)
        if bmp is not None:
            self.screen.blit(bmp, (x, y))
        else:
            self.screen.blit(self.font.render(t, True, (230, 230, 230)), (x, y))

    def _right_txt(self, t: str, right_x: int, y: int) -> None:
        """HUD数値を右揃えし、桁数が変わってもラベルへ食い込ませない。"""
        bmp = self.bitmap_font.render(t, scale=1)
        if bmp is not None:
            self.screen.blit(bmp, (right_x - bmp.get_width(), y))
        else:
            surf = self.font.render(t, True, (230, 230, 230))
            self.screen.blit(surf, (right_x - surf.get_width(), y))

    def _hud_value(self, t: str, right_x: int, y: int) -> None:
        """暗色サイドバー上でもビットマップ数字を読める背景帯を付ける。"""
        pygame.draw.rect(self.screen, GAME_BG_COLOR, pygame.Rect(right_x - 74, y - 1, 76, 18))
        self._right_txt(t, right_x, y)

    def _center_txt(self, t: str, y: int, scale: int = 2):
        bmp = self.bitmap_font.render(t, scale=scale)
        if bmp is not None:
            self.screen.blit(bmp, ((SCREEN_WIDTH - bmp.get_width()) // 2, y))
        else:
            surf = self.big_font.render(t, True, (230, 230, 230))
            self.screen.blit(surf, ((SCREEN_WIDTH - surf.get_width()) // 2, y))
