{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/block-puzzle/config.schema.json",
  "title": "Block Puzzle Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "start_level": { "type": "integer", "minimum": 0, "maximum": 9 },
    "keymap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "down": { "type": "string" },
        "a": { "type": "string" },
        "b": { "type": "string" },
        "start": { "type": "string" },
        "select": { "type": "string" }
      },
      "required": ["left", "right", "down", "a", "b", "start", "select"]
    },
    "randomizer_seed": { "type": "integer", "minimum": 0 }
  },
  "required": ["version", "start_level", "keymap"]
}
