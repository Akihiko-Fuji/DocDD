root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py,yml,yaml,json,ini,sql}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[results_record_db/WINDOWS_SETUP.md]
end_of_line = crlf
